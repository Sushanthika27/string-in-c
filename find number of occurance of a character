#include<stdio.h>
#include<string.h>
int main()
{
   int i=0,count=0;
   char str[100],ch;
   printf("\nEnter a string");
   fgets(str,sizeof(str),stdin);
   printf("\nEnter a character to find\t");
   scanf("%c",&ch);
   while(str[i]!='\0')
   {
      if(str[i]==ch)
      {
         count++;
      }
      i++;
   }
   printf("\nThe Given Character %c Reapeated %d times \n",ch,count);
   return 0;
}
