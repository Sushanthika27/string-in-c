#include<stdio.h>
#include<string.h>
int main()
{
   char str[50][100],t[100];
   int i,j,n;
   printf("enter number of string");
   scanf("%d",&n);
   printf("enter strings");
   for(i=0;i<n+1;i++)
   {
      gets(str[i]);
   }
   for(i=0;i<n-1;i++)
   {
   for(j=0;j<n-j-1;j++)
   {
      if(strcmp(str[j],str[j+1])>0)
      {
         strcpy(t,str[j]);
         strcpy(str[j],str[j+1]);
         strcpy(str[j+1],t);
      }
   }
   }
   printf("\nStrings are in alphabetical order");
   for(i=0;i<n+1;i++)
   {
      printf("%s\n",str[i]);
   }
    return 0;
}
