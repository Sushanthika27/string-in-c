#include<stdio.h>
#include<string.h>
int main()
{
   int i=0,alphabets=0,digit=0,space=0,special=0;
   char str[100];
   printf("\nEnter the string");
   fgets(str,sizeof(str),stdin);
   while(str[i]!='\0')
   {
      if(isalpha(str[i]))
      {
         alphabets++;
      }
      else if(isdigit(str[i]))
      {
         digit++;
      }
      else if(isspace(str[i]))
      {
         space++;
      }
      else
      {
         special++;
      }
   i++;
   }
   printf("\nAlphabets=%d,\nDigit=%d,\nspace=%d,\nspecialcharacter=%d",alphabets,digit,space,special);
   return 0;
}
